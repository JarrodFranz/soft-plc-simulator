{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PLC Project Schema",
  "type": "object",
  "properties": {
    "project": {
      "type": "object",
      "required": ["name", "version", "controller", "tags", "programs"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "description": { "type": "string" },
        "controller": {
          "type": "object",
          "required": ["name", "scan_period_ms"],
          "properties": {
            "name": { "type": "string" },
            "scan_period_ms": { "type": "integer", "minimum": 10 }
          }
        },
        "tags": { "type": "array" },
        "programs": { "type": "array" }
      }
    }
  }
}
